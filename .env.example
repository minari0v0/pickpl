# 여기에 각자의 로컬 비밀번호를 적어서 .env 파일로 이름을 바꿔 사용하세요.
# ───────────────────────────────────────
# Database
# ───────────────────────────────────────
DB_DATABASE=pickpl
DB_ROOT_PASSWORD=

# ───────────────────────────────────────
# OAuth2
# ───────────────────────────────────────

# Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Kakao
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=

# Naver
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=

# ───────────────────────────────────────
# Administrator Security
# ───────────────────────────────────────
# 데이터 파이프라인(make pipe-load) 및 CMS 인증을 위한 기본 비밀번호
ADMIN_SECRET_KEY=

# ───────────────────────────────────────
# Gemini AI API
# ───────────────────────────────────────
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_KEY=

# ───────────────────────────────────────
# Crawler Settings
# ───────────────────────────────────────
SEARCH_SOURCE=naver
# 백엔드 연동 API 주소 (필요 시 수정)
BACKEND_URL=http://localhost:8080

# ───────────────────────────────────────
# Email Verification SMTP (PickPl)
# ───────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
