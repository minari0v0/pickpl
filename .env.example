# 여기에 각자의 로컬 비밀번호를 적어서 .env 파일로 이름을 바꿔 사용하세요.
# ───────────────────────────────────────
# Database
# ───────────────────────────────────────
DB_DATABASE=pickpl
DB_ROOT_PASSWORD=

# ───────────────────────────────────────
# OAuth2
# ───────────────────────────────────────

# Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Kakao
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=

# Naver
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=

# 관리자 전용 내부 API 시크릿 키 (파이썬 데이터 주입용)
ADMIN_SECRET_KEY=
